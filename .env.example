# Docker Compose variable substitution
# Copy this file to .env (gitignored) and fill in your local paths.
# These are NOT passed into the container — they only tell Compose where
# to source the volume mounts.

# Host-side path to the repo Ariadne should investigate (read-only mount)
ARIADNE_REPO_HOST_PATH=/path/to/repo/to/inspect

# Host-side path where Ariadne will write implementation briefs (writable mount).
# Typically the .ariadne directory inside the repo, e.g.:
# ARIADNE_BRIEFS_HOST_PATH=/path/to/repo/to/inspect/.ariadne
ARIADNE_BRIEFS_HOST_PATH=/path/to/repo/to/inspect/.ariadne

# Host-side directory where session logs will be persisted
LOGS_HOST_PATH=/path/to/logs
