# Required API keys
OPENAI_API_KEY="your_openai_api_key"
DEEPGRAM_API_KEY="your_deepgram_api_key"
CARTESIA_API_KEY="your_cartesia_api_key"
DAILY_API_KEY="your_daily_api_key"

# Models (defaults shown)
OPENAI_MODEL=gpt-4.1

# Ariadne home directory for logs, transcripts, and project backgrounds.
# Defaults to ~/.ariadne when unset.
# ARIADNE_HOME="$HOME/.ariadne"

# Repo to inspect (required for repo investigation and write-doc tasks)
ARIADNE_REPO_PATH="/absolute/path/to/repo/to/inspect"

# Optional: path to a pre-generated PROJECT_BACKGROUND.md for the target repo.
# Defaults to ~/.ariadne/project-backgrounds/<repo-name>-<hash>/PROJECT_BACKGROUND.md
# Run tools/refresh_project_background.sh to generate one.
# ARIADNE_PROJECT_BACKGROUND_PATH=""

# Optional: where session logs are written.
# Defaults to ~/.ariadne/logs
# LOGS_DIR=""

# Optional: where implementation briefs are written.
# Defaults to <ARIADNE_REPO_PATH>/.ariadne/briefs
# ARIADNE_BRIEFS_DIR=""

# Daily dial-in phone number (used by tools/build-deploy.sh to register the webhook)
DAILY_DIALIN_PHONE_NUMBER="+1XXXXXXXXXX"

# Debug server — disabled by default; enable for local development only.
ARIADNE_DEBUG_SERVER_ENABLED=false
ARIADNE_DEBUG_SERVER_HOST=127.0.0.1
ARIADNE_DEBUG_SERVER_PORT=8765

# Session idle timeout in seconds (default 300)
ARIADNE_IDLE_TIMEOUT_SECONDS=300
